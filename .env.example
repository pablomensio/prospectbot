# ============================================================
# MICROSERVICIO DE PROSPECCIÓN AUTOMATIZADA
# Copia este archivo, renombralo a .env y completa los valores
# ⚠️  NUNCA subas el archivo .env a git
# ============================================================

# --- APLICACIÓN ---
APP_NAME="Microservicio de Prospección Automatizada"
DEBUG=false

# --- EVOLUTION API ---
# URL de tu VPS donde corre Evolution API
EVOLUTION_API_URL=http://TU_VPS_IP:8080
# La API key que configuraste en Evolution API
EVOLUTION_API_KEY=tu-api-key-aqui
# Nombre de la instancia de WhatsApp en Evolution
EVOLUTION_INSTANCE=mi-instancia

# --- LLM (Inteligencia Artificial) ---
# Proveedor: "openai" | "gemini" | "ollama"
LLM_PROVIDER=openai
# Tu API Key de OpenAI (o Gemini)
LLM_API_KEY=sk-...
# Modelo a usar (gpt-4o-mini es el más barato y rápido para este uso)
LLM_MODEL=gpt-4o-mini
# URL base (solo cambiar para Gemini o Ollama)
# OpenAI:  https://api.openai.com/v1
# Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
# Ollama:  http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# --- WORKER (reglas anti-ban) ---
WORKER_BATCH_SIZE=5
# Delays en segundos entre mensajes (aleatorio entre MIN y MAX)
WORKER_DELAY_MIN=45
WORKER_DELAY_MAX=120
# Horario de envío (solo envía entre estas horas, formato 24h)
WORKER_HORA_INICIO=9
WORKER_HORA_FIN=20
# Límite de mensajes por día por número
WORKER_MAX_DIARIO=250

# --- CRM EXTERNO (Handoff) ---
# URL donde tu CRM recibirá el webhook cuando un lead esté caliente
CRM_WEBHOOK_URL=https://tu-crm.ejemplo.com/api/webhooks/lead-caliente
# Token de seguridad para que el CRM valide que el POST viene de este microservicio
CRM_WEBHOOK_SECRET=token-secreto-muy-largo-y-aleatorio
# Cuántas respuestas DUDA antes de escalar al CRM
MAX_DUDAS_ANTES_HANDOFF=3

# --- SEGURIDAD WEBHOOK ENTRANTE ---
# Token que Evolution API debe incluir en el header x-webhook-token
WEBHOOK_SECRET_TOKEN=otro-token-secreto-para-evolution
